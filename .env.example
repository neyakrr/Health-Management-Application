# =============================================================
# Health Concierge — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit your real .env file to version control.
# =============================================================

# ---------------------------
# NVIDIA NIM API
# ---------------------------
# Get your API key from: https://build.nvidia.com
# Sign up → Profile → API Keys → Generate Key
NVIDIA_API_KEY=nvapi-your-api-key-here

# ---------------------------
# JWT Authentication
# ---------------------------
# A long, random secret string used to sign JWT tokens.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=your-256-bit-secret-key-that-is-very-long-and-secure-change-this

# ---------------------------
# Email (Gmail SMTP)
# ---------------------------
# Used to send caregiver invitation emails.
#
# IMPORTANT: Use a Gmail App Password, NOT your regular Gmail password.
# How to get an App Password:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create a new App Password for "Mail"
#   4. Copy the 16-character code below (format: xxxx xxxx xxxx xxxx)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
